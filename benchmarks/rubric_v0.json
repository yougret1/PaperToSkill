{
  "schema_version": "0.1",
  "created": "2026-06-17",
  "purpose": "First deterministic rubric for paper-derived SKILL.md outputs.",
  "max_score": 20,
  "criteria": [
    {
      "id": "structure",
      "description": "Required skill sections are present.",
      "max_points": 6,
      "required_sections": [
        "Source",
        "Paper Snapshot",
        "Central Contribution",
        "Inputs",
        "Workflow",
        "Validation",
        "Failure Cases",
        "Transfer Notes"
      ]
    },
    {
      "id": "source_anchoring",
      "description": "Workflow, validation, and failure sections preserve source anchors.",
      "max_points": 3,
      "anchor_pattern": "Source anchors:"
    },
    {
      "id": "workflow_coverage",
      "description": "Key method concepts from the source paper are present in the generated workflow.",
      "max_points": 5,
      "keywords": [
        "generalized idea generation",
        "Experiment Progress Manager",
        "four stages",
        "parallelized agentic tree search",
        "buggy",
        "non-buggy",
        "replications",
        "aggregation"
      ]
    },
    {
      "id": "failure_coverage",
      "description": "Known limitations and ethical constraints are present.",
      "max_points": 4,
      "keywords": [
        "workshop-level",
        "one of three",
        "top-tier conference",
        "citation inaccuracies",
        "IRB",
        "withdrawal"
      ]
    },
    {
      "id": "compactness",
      "description": "Skill is compact enough for practical agent context.",
      "max_points": 2,
      "max_words": 1200
    }
  ]
}
