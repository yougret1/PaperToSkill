{
  "schema_version": "0.1",
  "id": "aide_harness_transfer",
  "created": "2026-06-17",
  "purpose": "Offline Codex-to-Claude-style harness transfer readiness evaluation for the AIDE paper-derived skill.",
  "evidence_boundary": "Offline deterministic readiness metric; not a live cross-harness agent run.",
  "context_variants": [
    {
      "id": "full_skill",
      "label": "PaperToSkill generated skill with transfer notes",
      "path": "generated_skills/aide/SKILL.md"
    },
    {
      "id": "skill_without_transfer_notes",
      "label": "Generated skill with Transfer Notes removed",
      "path": "generated_skills/aide/SKILL.md",
      "drop_sections": [
        "Transfer Notes"
      ]
    },
    {
      "id": "generic_summary",
      "label": "Generic prose summary baseline",
      "path": "baselines/aide_generic_summary.md"
    }
  ],
  "core_signal_groups": [
    {
      "id": "solution_tree_search",
      "keywords": [
        "solution tree",
        "objective function",
        "search policy",
        "best-scoring solution"
      ]
    },
    {
      "id": "coding_actions",
      "keywords": [
        "drafting",
        "debugging",
        "improving",
        "atomic measurable change"
      ]
    },
    {
      "id": "history_and_data_context",
      "keywords": [
        "summarization operator",
        "performance metrics",
        "hyperparameters",
        "data preview"
      ]
    },
    {
      "id": "validation_and_limits",
      "keywords": [
        "Weco-Kaggle",
        "MLE-Bench",
        "RE-Bench",
        "data contamination",
        "local optima",
        "LLM inference cost"
      ]
    }
  ],
  "target_harnesses": [
    {
      "id": "codex_skill",
      "label": "Codex-style SKILL.md harness",
      "required_sections": [
        "Inputs",
        "Workflow",
        "Validation",
        "Failure Cases",
        "Transfer Notes"
      ],
      "transfer_checks": [
        "target harness",
        "framework-specific commands",
        "local equivalents",
        "source-backed steps",
        "failed branch"
      ],
      "source_anchor_min": 8,
      "max_words": 1000
    },
    {
      "id": "claude_project_prompt",
      "label": "Claude-style project prompt harness",
      "required_sections": [
        "Paper Snapshot",
        "Workflow",
        "Validation",
        "Failure Cases",
        "Transfer Notes"
      ],
      "transfer_checks": [
        "target harness",
        "local equivalents",
        "source-backed steps",
        "inferred adaptations",
        "future revision history"
      ],
      "source_anchor_min": 8,
      "max_words": 1100
    }
  ]
}
