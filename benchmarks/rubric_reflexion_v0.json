{
  "schema_version": "0.1",
  "created": "2026-06-17",
  "purpose": "Deterministic v0 scoring rubric for Reflexion paper-derived skills.",
  "max_score": 20,
  "criteria": [
    {
      "id": "structure",
      "description": "Required skill sections are present.",
      "max_points": 6,
      "required_sections": [
        "Source",
        "Paper Snapshot",
        "Central Contribution",
        "Inputs",
        "Workflow",
        "Validation",
        "Failure Cases",
        "Transfer Notes"
      ]
    },
    {
      "id": "source_anchoring",
      "description": "Workflow, validation, and failure sections preserve source anchors.",
      "max_points": 3,
      "anchor_pattern": "Source anchors:"
    },
    {
      "id": "workflow_coverage",
      "description": "Key Reflexion method concepts are present in the generated workflow.",
      "max_points": 5,
      "keywords": [
        "Actor",
        "Evaluator",
        "Self-Reflection",
        "verbal self-reflections",
        "short-term memory",
        "long-term memory",
        "feedback",
        "memory buffer"
      ]
    },
    {
      "id": "failure_coverage",
      "description": "Known Reflexion limitations are present.",
      "max_points": 4,
      "keywords": [
        "local minima",
        "no formal guarantee",
        "sliding window",
        "advanced structures",
        "creative behavior",
        "richer interaction"
      ]
    },
    {
      "id": "compactness",
      "description": "Skill is compact enough for practical agent context.",
      "max_points": 2,
      "max_words": 1200
    }
  ]
}
